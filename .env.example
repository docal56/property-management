# Next.js / Vercel ────────────────────────────────────────

# Convex deployment URL.
# Local + Vercel Preview should point at the hosted cloud development deployment.
# Vercel Production should point at the production deployment.
# `pnpm exec convex dev` may write this to .env.local.
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key — Vercel Production build only.
# Leave unset for local dev and Vercel Preview while previews point at cloud dev.
# From: Convex dashboard → Settings → Deploy Keys (generate Production key).
CONVEX_DEPLOY_KEY=

# Clerk — clerk.com → your app → API Keys.
# Local + Vercel Preview use Clerk development keys (`pk_test_`, `sk_test_`).
# Vercel Production uses Clerk production keys (`pk_live_`, `sk_live_`).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT issuer / frontend API URL.
# Production currently uses: https://clerk.usebuzz.ai
# Also set this on the matching Convex deployment.
CLERK_JWT_ISSUER_DOMAIN=

# Amity tool-call API endpoints.
# Local dev can omit this while testing mocked endpoints.
# Production should set this and send it as either:
#   Authorization: Bearer <secret>
# or:
#   x-amity-tool-secret: <secret>
AMITY_TOOL_SECRET=

# ─── Convex deployment env (separate store; set via `npx convex env set`) ───
# Reference only — these DO NOT belong in this .env file:
#   APP_ENVIRONMENT             `production` or `development`; debug/audit label
#   CLERK_JWT_ISSUER_DOMAIN     same environment's Clerk issuer/frontend API URL
#   CLERK_WEBHOOK_SECRET        from the matching Clerk webhook endpoint
#   ELEVENLABS_WEBHOOK_SECRET   from the matching ElevenLabs agent post-call webhook
#   ANTHROPIC_API_KEY           used by the Convex extraction action (LLM fallback)
