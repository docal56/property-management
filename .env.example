# Environment variables for the Property Management app.
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Tech-spec section 3 is the source of truth for this list.

# ── Convex ────────────────────────────────────────────────────────────────
# Dev deployment URL and identifier. Populated automatically by
# `npx convex dev` — do not edit by hand.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# ── Clerk ─────────────────────────────────────────────────────────────────
# From the Clerk dashboard → API Keys. Use the dev instance keys locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing. Match the folder structure under /app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/open-issues

# ── ElevenLabs ────────────────────────────────────────────────────────────
# Shared secret validated by the Convex HTTP action at /elevenlabs/webhook.
# IMPORTANT: This is set in the Convex dashboard (Environment Variables) —
# NOT in Next.js .env.local. It is listed here only for completeness.
ELEVENLABS_WEBHOOK_SECRET=
