# Next.js / Vercel ────────────────────────────────────────

# Convex deployment URL — auto-written to .env.local by `pnpm dlx convex dev`.
# Leave blank here; set in Vercel env for prod (Vercel's build injects it).
NEXT_PUBLIC_CONVEX_URL=

# Convex deploy key — Vercel build only; NOT needed for local dev.
# From: Convex dashboard → Settings → Deploy Keys (generate Production key)
CONVEX_DEPLOY_KEY=

# Clerk — clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk JWT issuer — clerk.com → Configure → Sessions (the issuer URL)
# Also set this on the Convex deployment via `npx convex env set`
CLERK_JWT_ISSUER_DOMAIN=

# ─── Convex deployment env (separate store; set via `npx convex env set`) ───
# Reference only — these DO NOT belong in this .env file:
#   CLERK_JWT_ISSUER_DOMAIN   same value as above, set on the Convex deployment
#   CLERK_WEBHOOK_SECRET      from Clerk → Webhooks → your endpoint's signing secret
#                             (prod only; webhooks can't reach local without a tunnel)
